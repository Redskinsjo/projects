generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CandidateStatus {
  INVITED
  STARTED
  COMPLETED
  ANALYZED
  SHORTLISTED
  REJECTED
  HIRED
}

enum MessageRole {
  SYSTEM
  ASSISTANT
  USER
}

enum Recommendation {
  REJECT
  CONSIDER
  INTERVIEW
  STRONG_MATCH
}

enum EstimatedLevel {
  JUNIOR
  INTERMEDIATE
  SENIOR
  LEAD
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

enum CommunicationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum InvitationDeliveryStatus {
  PENDING
  SENT
  SIMULATED
  FAILED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  firstName           String?
  lastName            String?
  avatarUrl           String?
  emailVerifiedAt     DateTime?
  passwordCredential  PasswordCredential?
  oauthAccounts       OAuthAccount[]
  sessions            Session[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OAuthAccount {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          AuthProvider
  providerAccountId String
  email             String?
  displayName       String?
  firstName         String?
  lastName          String?
  avatarUrl         String?
  rawProfile        Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Company {
  id         String      @id @default(cuid())
  name       String
  recruiters Recruiter[]
  jobs       JobOffer[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Recruiter {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobOffer {
  id             String      @id @default(cuid())
  title          String
  description    String
  requiredSkills Json
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidates     Candidate[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Candidate {
  id               String            @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phoneNumber      String?
  resumeUrl        String?
  status           CandidateStatus   @default(INVITED)
  score            Float?
  jobOfferId       String
  jobOffer         JobOffer          @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  conversations    Conversation[]
  reports          Report[]
  invitationTokens InvitationToken[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model InvitationToken {
  id              String                    @id @default(cuid())
  token           String                    @unique
  candidateId     String
  candidate       Candidate                 @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  channel         CommunicationChannel?
  deliveryStatus  InvitationDeliveryStatus?
  deliveryMessage String?
  sentAt          DateTime?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime                  @default(now())
}

model Conversation {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  messages    Message[]
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Report {
  id             String         @id @default(cuid())
  candidateId    String
  candidate      Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  summary        String
  strengths      Json
  weaknesses     Json
  estimatedLevel EstimatedLevel
  score          Float
  recommendation Recommendation
  createdAt      DateTime       @default(now())
}
